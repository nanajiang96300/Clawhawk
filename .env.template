# ============================================================
# ClawHawk Agent Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Discord Bot Token (from https://discord.com/developers/applications)
CLAWHAWK_DISCORD_TOKEN=your_bot_token_here

# Discord User ID (enable Developer Mode → right-click your profile → Copy ID)
CLAWHAWK_DISCORD_USER_ID=your_discord_user_id_here

# Optional: Timezone (default: UTC+8)
CLAWHAWK_TIMEZONE=UTC+8

# Optional: Security level (locked | strict | moderate | unrestricted)
CLAWHAWK_SECURITY=moderate

# Optional: Web UI port (default: auto-select 4632-4641)
# CLAWHAWK_WEB_PORT=4632
